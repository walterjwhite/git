#!/bin/sh

. _LIBRARY_PATH_/install/logging.sh

if [ -z "$(git status --porcelain)" ]
then
    exitWithError "No changes" 1
fi

if [ "$(git log -1 2>/dev/null | grep commit | wc -l)" -gt "0" ]
then
    git diff --unified -w
else
    find . -type f\
    | grep -v \\.git\
    | xargs -L 1 -I _F $EDITOR _F
fi